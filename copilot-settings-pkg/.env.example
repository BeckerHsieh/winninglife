# 複製此檔為 .env 並填入實際值（此檔可安全提交，.env 不可提交）

# Firecrawl API Key（從 https://firecrawl.dev 取得）
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Filesystem MCP 允許存取的目錄（以空格分隔，Windows 路徑用雙反斜線）
FILESYSTEM_DIRS=C:\\Users\\%USERNAME%\\Desktop C:\\Users\\%USERNAME%\\Documents C:\\Users\\%USERNAME%\\Downloads
